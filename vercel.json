{
  "version": 2,

  "functions": {
    "app.py": {
      "memory": 1024,
      "maxDuration": 30
    }
  },

  "routes": [
    {
      "src": "/static/(.*)",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      },
      "dest": "/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "app.py"
    }
  ]
}
